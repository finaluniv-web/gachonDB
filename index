<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>가천대 체육학전공 실기 기록</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root{--blue:#1565c0;--sky:#42a5f5;--dark:#1a1a2e;--card:#fff;--bg:#f0f2f5;--text:#2c3e50;--sub:#7f8c8d;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Apple SD Gothic Neo',Arial,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
.header{background:linear-gradient(135deg,var(--dark) 0%,var(--blue) 50%,var(--sky) 100%);padding:28px 20px;position:relative;overflow:hidden;}
.header::before{content:'';position:absolute;width:200px;height:200px;background:rgba(255,255,255,0.05);border-radius:50%;top:-60px;right:-40px;pointer-events:none;}
.header::after{content:'';position:absolute;width:140px;height:140px;background:rgba(255,255,255,0.05);border-radius:50%;bottom:-40px;left:-20px;pointer-events:none;}
.header-inner{display:flex;align-items:center;gap:20px;position:relative;z-index:1;}
.header-logo-box{flex-shrink:0;background:#fff;border-radius:18px;padding:10px 14px;box-shadow:0 6px 24px rgba(0,0,0,0.20);display:flex;align-items:center;justify-content:center;width:100px;height:100px;}
.header-logo-box img{width:100%;height:100%;object-fit:contain;}
.header-logo-text{font-size:13px;font-weight:900;color:var(--blue);text-align:center;}
.header-info-col{flex:1;min-width:0;display:flex;flex-direction:column;gap:4px;}
.header-univ{color:rgba(255,255,255,0.80);font-size:12px;}
.header-name{color:#fff;font-size:30px;font-weight:900;letter-spacing:-1px;line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.header-school{color:rgba(255,255,255,0.80);font-size:13px;}
.header-badge{display:inline-block;background:rgba(255,255,255,0.20);color:#fff;font-size:12px;font-weight:700;padding:5px 16px;border-radius:50px;border:1.5px solid rgba(255,255,255,0.40);align-self:flex-start;margin-top:2px;}
.total-card{margin:16px 16px 0;background:linear-gradient(135deg,var(--blue),var(--sky));border-radius:20px;padding:20px 24px;color:#fff;box-shadow:0 8px 32px rgba(21,101,192,0.30);}
.total-label{font-size:13px;opacity:.85;margin-bottom:4px;}
.total-score{font-size:48px;font-weight:900;letter-spacing:-2px;line-height:1;}
.total-sub{font-size:13px;opacity:.80;margin-top:4px;}
.total-breakdown{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:16px;}
.tb-item{background:rgba(255,255,255,0.15);border-radius:12px;padding:10px 8px;text-align:center;}
.tb-item .val{font-size:20px;font-weight:800;}
.tb-item .lbl{font-size:11px;opacity:.80;margin-top:2px;}
.official-banner{margin:12px 16px 0;background:#fff;border-radius:16px;padding:16px;box-shadow:0 2px 12px rgba(0,0,0,0.08);border-left:4px solid var(--blue);}
.ob-title{font-size:12px;color:var(--sub);margin-bottom:8px;font-weight:600;}
.ob-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
.ob-item{text-align:center;}
.ob-item .ov{font-size:18px;font-weight:800;color:var(--blue);}
.ob-item .ol{font-size:11px;color:var(--sub);margin-top:2px;}
.acad-card{margin:12px 16px 0;background:#fff;border-radius:16px;padding:16px;box-shadow:0 2px 12px rgba(0,0,0,0.08);}
.acad-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:10px;}
.acad-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
.acad-item{background:var(--bg);border-radius:12px;padding:12px 10px;text-align:center;}
.acad-item .av{font-size:20px;font-weight:800;color:var(--dark);}
.acad-item .al{font-size:11px;color:var(--sub);margin-top:2px;}
.tabs{display:flex;margin:16px 16px 0;background:#fff;border-radius:14px;padding:4px;box-shadow:0 2px 8px rgba(0,0,0,0.06);}
.tab-btn{flex:1;padding:10px 0;border:none;background:transparent;border-radius:10px;font-size:14px;font-weight:600;color:var(--sub);cursor:pointer;transition:all .2s;}
.tab-btn.active{background:var(--blue);color:#fff;}
.chart-area{padding:12px 16px 24px;}
.event-card{background:#fff;border-radius:18px;margin-bottom:14px;box-shadow:0 2px 12px rgba(0,0,0,0.07);overflow:hidden;cursor:pointer;transition:box-shadow .2s;}
.event-card:hover{box-shadow:0 4px 20px rgba(0,0,0,0.13);}
.event-card-header{display:flex;align-items:center;justify-content:space-between;padding:14px 16px 0;}
.event-badge{background:var(--blue);color:#fff;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;}
.event-toggle-icon{font-size:18px;color:var(--sub);transition:transform .3s;user-select:none;}
.event-card.open .event-toggle-icon{transform:rotate(180deg);}
.event-title{font-size:15px;font-weight:800;padding:6px 16px 0;}
.event-meta{display:flex;gap:16px;padding:4px 16px 10px;}
.event-best{font-size:13px;color:var(--sub);}
.event-achieve{font-size:13px;font-weight:700;color:var(--blue);}
.progress-wrap{margin:0 16px 10px;background:var(--bg);border-radius:99px;height:6px;overflow:hidden;}
.progress-bar{height:100%;background:linear-gradient(90deg,var(--blue),var(--sky));border-radius:99px;transition:width .6s;}
.chart-toggle{display:flex;gap:8px;padding:0 16px 8px;}
.ct-btn{flex:1;padding:7px 0;border:1.5px solid var(--blue);border-radius:10px;background:transparent;color:var(--blue);font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;}
.ct-btn.active{background:var(--blue);color:#fff;}
canvas{display:block;padding:0 12px 12px;}
.event-detail-table{max-height:0;overflow:hidden;transition:max-height .4s ease;}
.event-card.open .event-detail-table{max-height:600px;}
.event-detail-wrap{padding:0 14px 14px;}
.event-detail-wrap table{width:100%;border-collapse:collapse;font-size:13px;}
.event-detail-wrap th{background:var(--bg);color:var(--sub);font-weight:700;padding:8px 6px;text-align:center;border-bottom:2px solid #e0e0e0;}
.event-detail-wrap td{padding:8px 6px;text-align:center;border-bottom:1px solid #f0f0f0;}
.event-detail-wrap tr:last-child td{border-bottom:none;}
.official-row td{background:#f0f4ff;font-weight:700;color:var(--blue);}
.official-tag{display:inline-block;background:var(--blue);color:#fff;font-size:10px;padding:2px 6px;border-radius:6px;margin-left:4px;}
.table-area{padding:12px 16px 24px;overflow-x:auto;}
.rec-table{width:100%;border-collapse:collapse;font-size:12px;background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.07);}
.rec-table th{background:var(--dark);color:#fff;padding:10px 8px;text-align:center;white-space:nowrap;}
.rec-table td{padding:9px 8px;text-align:center;border-bottom:1px solid #f0f0f0;white-space:nowrap;}
.rec-table tr.official-row{background:#f0f4ff;}
.rec-table tr.official-row td{font-weight:700;color:var(--blue);}
.tag{display:inline-block;font-size:10px;padding:2px 6px;border-radius:6px;font-weight:700;}
.tag-official{background:var(--blue);color:#fff;}
.tag-monthly{background:#eee;color:#555;}
.loading,.error{text-align:center;padding:60px 20px;font-size:15px;color:var(--sub);}
.error{color:#c0392b;}
</style>
</head>
<body>
<div id="chartArea"><div class="loading">⏳ 데이터 불러오는 중...</div></div>
<script>
const SHEET_ID  = '1-uvH7koGGIEYXO8mL56xVUbUWXEbNPVuVP3htZ2wQMY';
const SHEET_TAB = '가천대학교체육학전공';
const LOGO_SRC  = 'images/gachon.png';

const SCORE_TABLE={
  여:{
    strength:[{min:151,score:100},{min:141,score:98},{min:131,score:96},{min:121,score:94},{min:111,score:92},{min:101,score:90},{min:91,score:88},{min:81,score:86},{min:71,score:84},{min:61,score:82},{min:51,score:80},{min:41,score:75},{min:31,score:70},{min:21,score:65},{min:11,score:60},{min:0,score:55}],
    medicine:[{min:9.0,score:100},{min:8.5,score:98},{min:8.0,score:96},{min:7.5,score:94},{min:7.0,score:92},{min:6.5,score:90},{min:6.0,score:88},{min:5.5,score:86},{min:5.0,score:84},{min:4.5,score:82},{min:4.0,score:80},{min:3.5,score:75},{min:3.0,score:70},{min:2.5,score:65},{min:2.0,score:60},{min:0,score:55}],
    jump:[{min:211,score:100},{min:201,score:98},{min:191,score:96},{min:181,score:94},{min:171,score:92},{min:161,score:90},{min:151,score:88},{min:141,score:86},{min:131,score:84},{min:121,score:82},{min:111,score:80},{min:101,score:75},{min:91,score:70},{min:81,score:65},{min:71,score:60},{min:0,score:55}],
    run:[{max:8.60,score:100},{max:8.80,score:98},{max:9.00,score:96},{max:9.20,score:94},{max:9.40,score:92},{max:9.60,score:90},{max:9.80,score:88},{max:10.00,score:86},{max:10.20,score:84},{max:10.40,score:82},{max:10.60,score:80},{max:10.80,score:75},{max:11.00,score:70},{max:11.20,score:65},{max:11.40,score:60},{max:999,score:55}]
  },
  남:{
    strength:[{min:221,score:100},{min:211,score:98},{min:201,score:96},{min:191,score:94},{min:181,score:92},{min:171,score:90},{min:161,score:88},{min:151,score:86},{min:141,score:84},{min:131,score:82},{min:121,score:80},{min:111,score:75},{min:101,score:70},{min:91,score:65},{min:81,score:60},{min:0,score:55}],
    medicine:[{min:13.0,score:100},{min:12.5,score:98},{min:12.0,score:96},{min:11.5,score:94},{min:11.0,score:92},{min:10.5,score:90},{min:10.0,score:88},{min:9.5,score:86},{min:9.0,score:84},{min:8.5,score:82},{min:8.0,score:80},{min:7.5,score:75},{min:7.0,score:70},{min:6.5,score:65},{min:6.0,score:60},{min:0,score:55}],
    jump:[{min:261,score:100},{min:251,score:98},{min:241,score:96},{min:231,score:94},{min:221,score:92},{min:211,score:90},{min:201,score:88},{min:191,score:86},{min:181,score:84},{min:171,score:82},{min:161,score:80},{min:151,score:75},{min:141,score:70},{min:131,score:65},{min:121,score:60},{min:0,score:55}],
    run:[{max:7.80,score:100},{max:8.00,score:98},{max:8.20,score:96},{max:8.40,score:94},{max:8.60,score:92},{max:8.80,score:90},{max:9.00,score:88},{max:9.20,score:86},{max:9.40,score:84},{max:9.60,score:82},{max:9.80,score:80},{max:10.00,score:75},{max:10.20,score:70},{max:10.40,score:65},{max:10.60,score:60},{max:999,score:55}]
  }
};

function getScore(table,value){
  if(value===null||value===undefined)return null;
  for(const row of table){
    if(row.min!==undefined&&value>=row.min)return row.score;
    if(row.max!==undefined&&value<=row.max)return row.score;
  }
  return 55;
}

const EVENTS=[
  {key:'strength',label:'배근력',        unit_label:'kg',ci:'1'},
  {key:'medicine',label:'메디신볼 던지기',unit_label:'m', ci:'2'},
  {key:'jump',    label:'제자리멀리뛰기', unit_label:'cm',ci:'3'},
  {key:'run',     label:'10m 왕복달리기', unit_label:'초',ci:'4'}
];

const CSV_URL=`https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(SHEET_TAB)}`;

function parseCSV(text){
  const rows=[];const re=/("(?:[^"]|"")*"|[^,\n\r]*)/g;
  let row=[],m;
  while((m=re.exec(text))!==null){
    let v=m[1];
    if(v.startsWith('"')&&v.endsWith('"'))v=v.slice(1,-1).replace(/""/g,'"');
    row.push(v.trim());
    const nx=text[re.lastIndex];
    if(nx==='\n'||nx==='\r'||re.lastIndex>=text.length){
      rows.push(row);row=[];
      if(nx==='\r'&&text[re.lastIndex+1]==='\n')re.lastIndex++;
    }else if(nx===',')re.lastIndex++;
  }
  return rows;
}

function pv(v){if(!v||v.trim()==='')return null;const n=parseFloat(v.replace(/,/g,''));return isNaN(n)?null:n;}
function normalizeGender(v){const s=(v||'').trim();return(s==='여'||s==='여자')?'여':'남';}
function isOfficial(type){return(type||'').includes('공식');}

function parseStudent(name,rows){
  const records=[];
  for(let i=1;i<rows.length;i++){
    const r=rows[i];
    if(!r||r.length<8)continue;
    if((r[2]||'').trim()!==name)continue;
    const gKey=normalizeGender(r[3]);
    const tbl=SCORE_TABLE[gKey];
    const acadVal=pv(r[7]);
    const strVal =pv(r[8]);
    const medVal =pv(r[9]);
    const jmpVal =pv(r[10]);
    const runVal =pv(r[11]);
    const totalVal=pv(r[12]);
    records.push({
      type:(r[0]||'').trim(),date:(r[1]||'').trim(),
      name:(r[2]||'').trim(),gender:gKey,
      school:(r[4]||'').trim(),univ:(r[5]||'').trim(),dept:(r[6]||'').trim(),
      acad:acadVal,
      strength:strVal, strScore :getScore(tbl.strength,strVal),
      medicine:medVal, medScore :getScore(tbl.medicine,medVal),
      jump    :jmpVal, jumpScore:getScore(tbl.jump,jmpVal),
      run     :runVal, runScore :getScore(tbl.run,runVal),
      total:totalVal
    });
  }
  records.sort((a,b)=>{
    const da=a.date.replace(/\D/g,'').padEnd(8,'0');
    const db=b.date.replace(/\D/g,'').padEnd(8,'0');
    return da<db?-1:da>db?1:0;
  });
  return records;
}

let CHARTS={};

function renderHeader(r,el){
  const f=r[0]||{};
  el.innerHTML=`<div class="header"><div class="header-inner">
    <div class="header-logo-box">
      <img src="${LOGO_SRC}" alt="로고" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
      <span class="header-logo-text" style="display:none">${f.univ||'대학교'}</span>
    </div>
    <div class="header-info-col">
      <div class="header-univ">${f.univ||''} · ${f.dept||''}</div>
      <div class="header-name">${f.name||''}</div>
      <div class="header-school">${f.school||''}</div>
      <div class="header-badge">${f.gender==='여'?'여자':'남자'}</div>
    </div>
  </div></div>`;
}

function renderTotalCard(r,el){
  const off=r.filter(x=>isOfficial(x.type));
  const last=off.length?off[off.length-1]:r[r.length-1];
  if(!last){el.innerHTML='';return;}
  const acad=last.acad??0;
  const scores=[last.strScore,last.medScore,last.jumpScore,last.runScore];
  const allHave=scores.every(v=>v!==null);
  const calcSum=allHave?scores.reduce((a,b)=>a+b,0):null;
  let total=last.total;
  if(total===null&&allHave)total=Math.round((acad+calcSum*1.75)*100)/100;
  el.innerHTML=`<div class="total-card">
    <div class="total-label">최종 총점 (내신환산 + 종목합×1.75)</div>
    <div class="total-score">${total!==null?total.toFixed(2):'—'}</div>
    <div class="total-sub">내신환산 ${acad>0?acad.toFixed(2):'미입력'} + 종목합 ${calcSum!==null?calcSum:'—'} × 1.75</div>
    <div class="total-breakdown">
      <div class="tb-item"><div class="val">${last.strScore??'—'}</div><div class="lbl">배근력 점수</div></div>
      <div class="tb-item"><div class="val">${last.medScore??'—'}</div><div class="lbl">메디신볼 점수</div></div>
      <div class="tb-item"><div class="val">${last.jumpScore??'—'}</div><div class="lbl">멀리뛰기 점수</div></div>
      <div class="tb-item"><div class="val">${last.runScore??'—'}</div><div class="lbl">달리기 점수</div></div>
      <div class="tb-item"><div class="val">${acad>0?acad.toFixed(2):'—'}</div><div class="lbl">내신환산</div></div>
      <div class="tb-item"><div class="val">${total!==null?total.toFixed(2):'—'}</div><div class="lbl">총점</div></div>
    </div>
  </div>`;
}

function renderOfficialBanner(r,el){
  const off=r.filter(x=>isOfficial(x.type));
  if(!off.length){el.innerHTML='';return;}
  const last=off[off.length-1];
  el.innerHTML=`<div class="official-banner">
    <div class="ob-title">📋 공식 테스트 최신 기록 (${last.date})</div>
    <div class="ob-grid">
      <div class="ob-item"><div class="ov">${last.strength??'—'} <small>kg</small></div><div class="ol">배근력</div></div>
      <div class="ob-item"><div class="ov">${last.medicine??'—'} <small>m</small></div><div class="ol">메디신볼</div></div>
      <div class="ob-item"><div class="ov">${last.jump??'—'} <small>cm</small></div><div class="ol">멀리뛰기</div></div>
      <div class="ob-item"><div class="ov">${last.run??'—'} <small>초</small></div><div class="ol">왕복달리기</div></div>
    </div>
  </div>`;
}

function renderAcadCard(r,el){
  const off=r.filter(x=>isOfficial(x.type));
  const last=off.length?off[off.length-1]:r[r.length-1];
  if(!last||last.acad===null){el.innerHTML='';return;}
  el.innerHTML=`<div class="acad-card">
    <div class="acad-title">📚 내신환산 점수</div>
    <div class="acad-grid">
      <div class="acad-item"><div class="av">${last.acad.toFixed(2)}</div><div class="al">내신환산 점수</div></div>
      <div class="acad-item"><div class="av">${((last.acad/300)*100).toFixed(1)}%</div><div class="al">내신 달성률 (300점 기준)</div></div>
    </div>
  </div>`;
}

function buildDetailTable(records,key,unit){
  const sk={strength:'strScore',medicine:'medScore',jump:'jumpScore',run:'runScore'}[key];
  const rows=records.map(rec=>{
    const v=rec[key];const s=rec[sk];
    const isOff=isOfficial(rec.type);
    return `<tr class="${isOff?'official-row':''}">
      <td>${rec.date}${isOff?'<span class="official-tag">공식</span>':''}</td>
      <td>${v!==null?v+' '+unit:'—'}</td>
      <td>${s!==null?s:'—'}</td>
    </tr>`;
  }).join('');
  return `<div class="event-detail-wrap"><table>
    <thead><tr><th>날짜</th><th>기록</th><th>배점</th></tr></thead>
    <tbody>${rows}</tbody>
  </table></div>`;
}

function renderChartTab(records,el){
  Object.values(CHARTS).forEach(c=>c.destroy());CHARTS={};
  const sk={strength:'strScore',medicine:'medScore',jump:'jumpScore',run:'runScore'};
  const um={strength:'kg',medicine:'m',jump:'cm',run:'초'};
  let html='<div class="chart-area">';
  EVENTS.forEach(ev=>{
    const scores=records.map(x=>x[sk[ev.key]]).filter(s=>s!==null);
    const best=scores.length?Math.max(...scores):null;
    const latest=scores.length?scores[scores.length-1]:55;
    const pct=Math.max(0,Math.min(100,Math.round(((latest-55)/(100-55))*100)));
    const detail=buildDetailTable(records,ev.key,um[ev.key]);
    html+=`<div class="event-card" id="card-${ev.key}" onclick="toggleCard('${ev.key}',event)">
      <div class="event-card-header">
        <span class="event-badge">종목 ${ev.ci}</span>
        <span class="event-toggle-icon" id="icon-${ev.key}">▼</span>
      </div>
      <div class="event-title">${ev.label}</div>
      <div class="event-meta">
        <span class="event-best">최고 ${best!==null?best:'—'} 점</span>
        <span class="event-achieve">달성률 ${pct}%</span>
      </div>
      <div class="progress-wrap"><div class="progress-bar" style="width:${pct}%"></div></div>
      <div class="chart-toggle">
        <button class="ct-btn active" id="btn-line-${ev.key}" onclick="switchChartType('${ev.key}','line',event)">꺾은선</button>
        <button class="ct-btn" id="btn-bar-${ev.key}" onclick="switchChartType('${ev.key}','bar',event)">막대</button>
      </div>
      <canvas id="canvas-${ev.key}" height="160"></canvas>
      <div class="event-detail-table" id="detail-${ev.key}">${detail}</div>
    </div>`;
  });
  html+='</div>';
  el.innerHTML=html;
  EVENTS.forEach(ev=>buildChart(ev.key,records,sk[ev.key],'line'));
}

function buildChart(key,records,sk,type){
  const ctx=document.getElementById('canvas-'+key);
  if(!ctx)return;
  if(CHARTS[key])CHARTS[key].destroy();
  const labels=records.map(r=>r.date);
  const data=records.map(r=>r[sk]);
  const isOff=records.map(r=>isOfficial(r.type));
  CHARTS[key]=new Chart(ctx,{
    type,
    data:{labels,datasets:[{
      label:'배점',data,
      borderColor:'#1565c0',
      backgroundColor:type==='bar'?'rgba(21,101,192,0.7)':'rgba(21,101,192,0.15)',
      fill:type==='line',tension:0.3,
      pointBackgroundColor:isOff.map(o=>o?'#1565c0':'#42a5f5'),
      pointRadius:isOff.map(o=>o?7:4),
      pointBorderWidth:2,pointBorderColor:'#fff'
    }]},
    options:{responsive:true,plugins:{legend:{display:false}},
      scales:{y:{min:50,max:100,ticks:{stepSize:10}}}}
  });
}

function switchChartType(key,type,e){
  e.stopPropagation();
  ['line','bar'].forEach(t=>{
    const b=document.getElementById(`btn-${t}-${key}`);
    if(b)b.classList.toggle('active',t===type);
  });
  const sk={strength:'strScore',medicine:'medScore',jump:'jumpScore',run:'runScore'};
  buildChart(key,window._RECORDS||[],sk[key],type);
}

function toggleCard(key,e){
  if(e.target.closest('.chart-toggle'))return;
  document.getElementById('card-'+key)?.classList.toggle('open');
}

function renderTableTab(records,el){
  const rows=records.map(r=>{
    const acad=r.acad??0;
    const scores=[r.strScore,r.medScore,r.jumpScore,r.runScore];
    const allHave=scores.every(v=>v!==null);
    const calcSum=allHave?scores.reduce((a,b)=>a+b,0):null;
    let tot=r.total;
    if(tot===null&&allHave)tot=Math.round((acad+calcSum*1.75)*100)/100;
    const isOff=isOfficial(r.type);
    return `<tr class="${isOff?'official-row':''}">
      <td><span class="tag ${isOff?'tag-official':'tag-monthly'}">${r.type}</span></td>
      <td>${r.date}</td>
      <td>${r.strength??'—'}</td><td>${r.strScore??'—'}</td>
      <td>${r.medicine??'—'}</td><td>${r.medScore??'—'}</td>
      <td>${r.jump??'—'}</td><td>${r.jumpScore??'—'}</td>
      <td>${r.run??'—'}</td><td>${r.runScore??'—'}</td>
      <td>${acad>0?acad.toFixed(2):'—'}</td>
      <td><strong>${tot!==null?tot.toFixed(2):'—'}</strong></td>
    </tr>`;
  }).join('');
  el.innerHTML=`<div class="table-area"><table class="rec-table">
    <thead><tr>
      <th>구분</th><th>날짜</th>
      <th>배근력</th><th>점수</th>
      <th>메디신볼</th><th>점수</th>
      <th>멀리뛰기</th><th>점수</th>
      <th>왕복달리기</th><th>점수</th>
      <th>내신환산</th><th>총점</th>
    </tr></thead>
    <tbody>${rows}</tbody>
  </table></div>`;
}

(async()=>{
  const app=document.getElementById('chartArea');
  const name=new URLSearchParams(location.search).get('name')||'';
  if(!name){app.innerHTML='<div class="error">❌ URL에 ?name=학생이름 을 추가해주세요.</div>';return;}
  try{
    const res=await fetch(CSV_URL);
    if(!res.ok)throw new Error('HTTP '+res.status);
    const text=await res.text();
    const rows=parseCSV(text);
    const records=parseStudent(name,rows);
    if(!records.length){
      app.innerHTML=`<div class="error">❌ "${name}" 학생을 찾을 수 없습니다.<br><small>이름 철자와 시트 탭명을 확인해주세요.</small></div>`;
      return;
    }
    window._RECORDS=records;
    const header=document.createElement('div');
    const totalCard=document.createElement('div');
    const officialBanner=document.createElement('div');
    const acadCard=document.createElement('div');
    const tabWrap=document.createElement('div');tabWrap.className='tabs';
    tabWrap.innerHTML=`<button class="tab-btn active" id="tab-chart" onclick="showTab('chart')">📈 차트</button><button class="tab-btn" id="tab-table" onclick="showTab('table')">📋 기록표</button>`;
    const chartContent=document.createElement('div');chartContent.id='content-chart';
    const tableContent=document.createElement('div');tableContent.id='content-table';tableContent.style.display='none';
    renderHeader(records,header);
    renderTotalCard(records,totalCard);
    renderOfficialBanner(records,officialBanner);
    renderAcadCard(records,acadCard);
    renderChartTab(records,chartContent);
    renderTableTab(records,tableContent);
    app.innerHTML='';
    [header,totalCard,officialBanner,acadCard,tabWrap,chartContent,tableContent].forEach(e=>app.appendChild(e));
    window.showTab=function(tab){
      document.getElementById('content-chart').style.display=tab==='chart'?'':'none';
      document.getElementById('content-table').style.display=tab==='table'?'':'none';
      document.getElementById('tab-chart').classList.toggle('active',tab==='chart');
      document.getElementById('tab-table').classList.toggle('active',tab==='table');
    };
  }catch(err){
    app.innerHTML=`<div class="error">❌ 데이터 로드 실패: ${err.message}</div>`;
  }
})();
</script>
</body>
</html>

  { key:'jump',     label:'제자리 멀리뛰기', unit:'cm', ci:'3', col:12, scol:13 },
  { key:'run',      label:'10m 왕복달리기',  unit:'초', ci:'4', col:14, scol:15 }
];

const LINE_C = [
  { line:'#0D47A1', fill:'rgba(13,71,161,0.07)'   },
  { line:'#1565C0', fill:'rgba(21,101,192,0.07)'  },
  { line:'#1E88E5', fill:'rgba(30,136,229,0.07)'  },
  { line:'#42A5F5', fill:'rgba(66,165,245,0.07)'  }
];
const BAR_C = [
  'rgba(13,71,161,0.80)','rgba(21,101,192,0.80)',
  'rgba(30,136,229,0.80)','rgba(66,165,245,0.80)'
];

/* ── 전역 상태 ── */
let chartInst  = {};
let chartTypes = {};
let studentData = null;
const urlName = new URLSearchParams(window.location.search).get('name') || '';

/* ── CSV 로드 ── */
const CSV_URL =
  `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(SHEET_TAB)}`;

fetch(CSV_URL)
  .then(r => r.text())
  .then(csv => {
    const rows = parseCSV(csv);
    const data = parseStudent(rows, urlName);
    if (!data) {
      document.getElementById('chartArea').innerHTML =
        `<div class="loading">❌ <b>${urlName || '(이름 없음)'}</b> 데이터를 찾을 수 없어요.<br>URL ?name= 값을 확인해주세요.</div>`;
      return;
    }
    studentData = data;
    renderHeader(data);
    renderTotalCard(data);
    renderOfficialBanner(data);
    renderAcadCard(data);
    renderChartTab(data);
    renderTableTab(data);
  })
  .catch(() => {
    document.getElementById('chartArea').innerHTML =
      '<div class="loading">❌ 데이터를 불러올 수 없어요.<br>구글 시트 공개 설정을 확인해주세요.</div>';
  });

/* ── CSV 파싱 ── */
function parseCSV(text) {
  return text.trim().split('\n').map(line => {
    const res = []; let cur = '', inQ = false;
    for (const ch of line) {
      if (ch === '"') { inQ = !inQ; }
      else if (ch === ',' && !inQ) { res.push(cur.trim()); cur = ''; }
      else { cur += ch; }
    }
    res.push(cur.trim());
    return res;
  });
}

function parseVal(v) {
  if (v === undefined || v === null) return null;
  const s = String(v).trim();
  if (s === '') return null;
  if (s === '미응시') return '미응시';
  const n = parseFloat(s);
  return isNaN(n) ? null : n;
}

/* ── 학생 데이터 추출 ── */
function parseStudent(rows, name) {
  if (!name) return null;
  const official = [], monthly = [];
  let gender = '남', school = '', univ = '', dept = '', acadScore = null;

  for (let i = 1; i < rows.length; i++) {
    const r = rows[i];
    if (!r[2] || r[2] !== name) continue;

    gender = r[3] || '남';
    school = r[4] || '';
    univ   = r[5] || '';
    dept   = r[6] || '';
    const hv = r[7] ? parseFloat(r[7]) : NaN;
    if (!isNaN(hv)) acadScore = hv;

    const gKey = (gender === '여') ? '여' : '남';
    const strVal = parseVal(r[8]);
    const medVal = parseVal(r[10]);
    const jmpVal = parseVal(r[12]);
    const runVal = parseVal(r[14]);

    const item = {
      type:     r[0] || '',
      date:     r[1] || '',
      strength: strVal,
      strScore: parseVal(r[9])  !== null ? parseVal(r[9])  : getScore(SCORE_TABLE[gKey].strength, strVal),
      medicine: medVal,
      medScore: parseVal(r[11]) !== null ? parseVal(r[11]) : getScore(SCORE_TABLE[gKey].medicine, medVal),
      jump:     jmpVal,
      jmpScore: parseVal(r[13]) !== null ? parseVal(r[13]) : getScore(SCORE_TABLE[gKey].jump,     jmpVal),
      run:      runVal,
      runScore: parseVal(r[15]) !== null ? parseVal(r[15]) : getScore(SCORE_TABLE[gKey].run,      runVal),
      total:    parseVal(r[16])
    };

    if (r[0] && r[0].includes('공식')) official.push(item);
    else monthly.push(item);
  }

  if (!official.length && !monthly.length) return null;
  monthly.sort((a, b) => String(a.date).localeCompare(String(b.date)));
  return { name, gender, school, univ, dept, acadScore, official, monthly };
}

/* ── 헤더 ── */
function renderHeader(d) {
  const univStr = [d.univ, d.dept].filter(Boolean).join(' · ') || 'Gachon University';
  document.getElementById('hUniv').textContent   = univStr;
  document.getElementById('hName').textContent   = d.name;
  document.getElementById('hSchool').textContent = d.school || '';
  document.getElementById('hBadge').textContent  = d.gender === '여' ? '👩 여성' : '🧑 남성';
}

/* ── 총점 카드 ── */
function renderTotalCard(d) {
  const allSorted = [...d.official, ...d.monthly]
    .sort((a, b) => String(b.date).localeCompare(String(a.date)));
  let recent = null;
  for (const r of allSorted) {
    if (r.total !== null && typeof r.total === 'number') { recent = r; break; }
  }
  if (!recent) return;

  document.getElementById('totalCard').style.display = '';
  document.getElementById('totalScore').textContent  = recent.total.toFixed(2);

  const acadMax = d.acadScore !== null ? d.acadScore : 0;
  document.getElementById('totalScoreSub').innerHTML =
    `실기만점 700${d.acadScore !== null ? ` + 내신 ${d.acadScore}` : ''}<br>최대 ${(700 + acadMax).toFixed(2)}점`;

  const chips = [];
  if (d.acadScore !== null) chips.push(`🎓 내신환산 <b>${d.acadScore}</b>`);
  const scores = [recent.strScore, recent.medScore, recent.jmpScore, recent.runScore]
    .filter(v => typeof v === 'number');
  if (scores.length) {
    const sum = scores.reduce((a, c) => a + c, 0);
    chips.push(`💪 실기합계(×1.75) <b>${(sum * 1.75).toFixed(2)}</b>`);
  }
  document.getElementById('totalBreakdown').innerHTML =
    chips.map(c => `<div class="total-chip">${c}</div>`).join('');
}

/* ── 공식 테스트 배너 ── */
function renderOfficialBanner(d) {
  const banner = document.getElementById('officialBanner');
  if (!d.official.length) { banner.innerHTML = ''; return; }
  const ov = d.official[d.official.length - 1];
  banner.innerHTML = `
    <div class="official-banner">
      <div class="official-banner-title">🏅 공식 테스트 최근 기록</div>
      <div class="official-banner-date">측정일 : ${ov.date}</div>
      <div class="official-grid">
        ${makeOB('배근력',         ov.strength, 'kg', ov.strScore)}
        ${makeOB('메디신볼 던지기', ov.medicine, 'm',  ov.medScore)}
        ${makeOB('제자리 멀리뛰기', ov.jump,     'cm', ov.jmpScore)}
        ${makeOB('10m 왕복달리기', ov.run,      '초', ov.runScore)}
      </div>
    </div>`;
}

function makeOB(label, val, unit, score) {
  const vStr = val === null ? '-' : (val === '미응시' ? '미응시' : String(val));
  const uStr = (val !== null && val !== '미응시') ? unit : '';
  const sEl  = typeof score === 'number'
    ? `<div class="official-item-score">배점 ${score}점</div>`
    : (score === '미응시' ? '<div class="official-item-score">미응시 (0점)</div>' : '');
  return `
    <div class="official-item">
      <div class="official-item-label">${label}</div>
      <span class="official-item-value">${vStr}</span>
      <span class="official-item-unit">${uStr}</span>
      ${sEl}
    </div>`;
}

/* ── 내신환산 카드 ── */
function renderAcadCard(d) {
  const card = document.getElementById('acadCard');
  if (d.acadScore !== null) {
    card.style.display = '';
    document.getElementById('acadVal').textContent = d.acadScore;
  } else {
    card.style.display = 'none';
  }
}

/* ── 탭 전환 ── */
function switchTab(name) {
  document.querySelectorAll('.tab-btn').forEach((b, i) => {
    b.classList.toggle('active', ['chart','table'][i] === name);
  });
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
}

/* ── 차트 탭 ── */
function renderChartTab(d) {
  const area   = document.getElementById('chartArea');
  area.innerHTML = '';
  const mData  = d.monthly;
  const labels = mData.map(r => r.date);
  const gKey   = (d.gender === '여') ? '여' : '남';

  const scoreKeys = {
    strength:'strScore', medicine:'medScore', jump:'jmpScore', run:'runScore'
  };

  EVENTS.forEach((ev, idx) => {
    const values = mData.map(r => {
      const v = r[ev.key];
      return (v !== null && v !== '미응시') ? v : null;
    });
    const scoreVals = mData.map(r => {
      const s = r[scoreKeys[ev.key]];
      return typeof s === 'number' ? s : null;
    });
    const valid = values.filter(v => v !== null);
    const isRun = ev.key === 'run';
    const best  = valid.length ? (isRun ? Math.min(...valid) : Math.max(...valid)) : null;
    const bestScore = best !== null ? getScore(SCORE_TABLE[gKey][ev.key], best) : 0;
    const pct = Math.round(bestScore);

    const card = document.createElement('div');
    card.className = 'event-card';
    card.innerHTML = `
      <div class="event-header">
        <div class="event-logo-box el${ev.ci}">
          <img src="${LOGO_SRC}" alt="가천대"
            onerror="this.parentElement.innerHTML='<span style=font-size:22px>🏅</span>'">
        </div>
        <div>
          <div class="event-title">${ev.label}</div>
          <div class="event-meta">단위: ${ev.unit} &nbsp;|&nbsp; 만점: 100점</div>
        </div>
      </div>
      <div class="stat-row">
        <div>
          <div class="best-label">월별 최고기록</div>
          <span class="best-record br${ev.ci}">${best !== null ? best : '-'}</span>
          <span class="best-unit">${best !== null ? ev.unit : ''}</span>
        </div>
        <div class="achievement">
          <div class="ach-label">배점</div>
          <div class="ach-pct ap${ev.ci}">${bestScore}점</div>
        </div>
      </div>
      <div class="progress-wrap">
        <div class="progress-bar pb${ev.ci}" id="pb_${ev.key}" style="width:0%"></div>
      </div>
      <div class="progress-meta">
        <span>0점</span>
        <span>만점 100점</span>
      </div>
      <div class="chart-toggle">
        <button class="chart-toggle-btn active" id="btn_line_${ev.key}"
          onclick="switchChartType('${ev.key}','line')">꺾은선</button>
        <button class="chart-toggle-btn" id="btn_bar_${ev.key}"
          onclick="switchChartType('${ev.key}','bar')">막대</button>
      </div>
      <div class="chart-wrap">
        <canvas id="chart_${ev.key}"></canvas>
      </div>`;
    area.appendChild(card);

    setTimeout(() => {
      const pb = document.getElementById('pb_' + ev.key);
      if (pb) pb.style.width = pct + '%';
    }, 150);

    chartTypes[ev.key] = 'line';
    buildChart(ev.key, 'line', labels, values, ev.unit, idx);
  });
}

/* ── 차트 생성 ── */
function buildChart(key, type, labels, values, unit, idx) {
  const canvas = document.getElementById('chart_' + key);
  if (!canvas) return;
  if (chartInst[key]) { chartInst[key].destroy(); delete chartInst[key]; }

  const lc     = LINE_C[idx];
  const isLine = (type === 'line');

  chartInst[key] = new Chart(canvas, {
    type: isLine ? 'line' : 'bar',
    data: {
      labels,
      datasets: [{
        label: unit,
        data: values,
        borderColor:          isLine ? lc.line : undefined,
        backgroundColor:      isLine ? lc.fill : BAR_C[idx],
        borderWidth:          isLine ? 2.5 : 0,
        pointRadius:          isLine ? 5   : 0,
        pointBackgroundColor: isLine ? lc.line : undefined,
        fill:                 isLine,
        tension:              0.35,
        spanGaps:             true,
        borderRadius:         isLine ? 0 : 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 600 },
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => ctx.parsed.y !== null ? `${ctx.parsed.y}${unit}` : '미응시'
          }
        }
      },
      scales: {
        x: { grid:{ display:false }, ticks:{ font:{ size:11 }, color:'#aaa' } },
        y: { grid:{ color:'#eef2f8' }, ticks:{ font:{ size:11 }, color:'#aaa' } }
      }
    }
  });
}

/* ── 꺾은선 ↔ 막대 ── */
function switchChartType(key, type) {
  if (chartTypes[key] === type) return;
  chartTypes[key] = type;
  document.getElementById('btn_line_' + key).classList.toggle('active', type === 'line');
  document.getElementById('btn_bar_'  + key).classList.toggle('active', type === 'bar');

  const d      = studentData;
  const ev     = EVENTS.find(e => e.key === key);
  const idx    = EVENTS.indexOf(ev);
  const mData  = d.monthly;
  const labels = mData.map(r => r.date);
  const values = mData.map(r => {
    const v = r[key];
    return (v !== null && v !== '미응시') ? v : null;
  });
  buildChart(key, type, labels, values, ev.unit, idx);
}

/* ── 기록표 탭 ── */
function renderTableTab(d) {
  const area = document.getElementById('tableArea');
  const allRows = [
    ...d.official.map(r => ({ ...r, isOfficial:true  })),
    ...d.monthly.map( r => ({ ...r, isOfficial:false }))
  ].sort((a, b) => String(b.date).localeCompare(String(a.date)));

  const fmtV = v => v === null ? '-' : (v === '미응시' ? '미응시' : String(v));
  const fmtS = v => {
    if (v === null) return '-';
    if (v === '미응시') return '0';
    return typeof v === 'number' ? String(v) : String(v);
  };
  const fmtT = v => {
    if (v === null || v === '미응시') return '-';
    return typeof v === 'number' ? v.toFixed(2) : String(v);
  };

  let html = `
    <div class="table-section">
      <div class="table-section-title">전체 기록표</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>날짜</th>
              <th>배근력<br><small style="opacity:.75;font-weight:400">kg</small></th>
              <th>점수</th>
              <th>메디신볼<br><small style="opacity:.75;font-weight:400">m</small></th>
              <th>점수</th>
              <th>멀리뛰기<br><small style="opacity:.75;font-weight:400">cm</small></th>
              <th>점수</th>
              <th>왕복달리기<br><small style="opacity:.75;font-weight:400">초</small></th>
              <th>점수</th>
              <th>총점</th>
            </tr>
          </thead>
          <tbody>`;

  allRows.forEach(r => {
    const cls = r.isOfficial ? 'official-row' : '';
    const tag = r.isOfficial
      ? `<br><span class="tag-official">공식</span>`
      : `<br><span class="tag-monthly">연습</span>`;
    html += `
      <tr class="${cls}">
        <td>${r.date}${tag}</td>
        <td>${fmtV(r.strength)}</td><td>${fmtS(r.strScore)}</td>
        <td>${fmtV(r.medicine)}</td><td>${fmtS(r.medScore)}</td>
        <td>${fmtV(r.jump)}</td>   <td>${fmtS(r.jmpScore)}</td>
        <td>${fmtV(r.run)}</td>    <td>${fmtS(r.runScore)}</td>
        <td><b>${fmtT(r.total)}</b></td>
      </tr>`;
  });

  html += `</tbody></table></div></div>`;
  area.innerHTML = html;
}
</script>
